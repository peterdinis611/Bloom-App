{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloom",
  "version": "0.1.0",
  "identifier": "com.peterdinis.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Bloom",
        "label": "main",
        "width": 720,
        "height": 640,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Movies/Bloom/**",
          "$HOME/Videos/Bloom/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
